{
    "name": "rucaro/accounting",
    "description": "Rucaro Accounting - modernised PHP 8.3 + MariaDB 10.11 stack (Phase 1 baseline).",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": "^8.3",
        "ext-openssl": "*",
        "ext-pdo": "*",
        "ext-mbstring": "*",
        "ext-json": "*",
        "smarty/smarty": "^5.7",
        "vlucas/phpdotenv": "^5.6",
        "monolog/monolog": "^3.7",
        "symfony/polyfill-mbstring": "^1.33",
        "nikic/fast-route": "^1.3",
        "guzzlehttp/guzzle": "^7.9",
        "symfony/console": "^7.1",
        "symfony/mailer": "^7.1",
        "ramsey/uuid": "^4.7",
        "dompdf/dompdf": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.4",
        "phpstan/phpstan": "^1.12",
        "vimeo/psalm": "^6.0 || ^7.0 || ^8.0",
        "friendsofphp/php-cs-fixer": "^3.64",
        "rector/rector": "^1.2",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Rucaro\\": "src/"
        },
        "classmap": [
            "back/class/else/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Rucaro\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": [
            "@test:unit",
            "@test:integration"
        ],
        "test:unit": "phpunit --testsuite=Unit --colors=always",
        "test:integration": "phpunit --testsuite=Integration --colors=always",
        "phpstan": "phpstan analyse --memory-limit=512M",
        "psalm": "psalm --no-cache",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "rector": "rector process --dry-run"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "platform": {
            "php": "8.3.30"
        },
        "allow-plugins": {
            "composer/package-versions-deprecated": false
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
