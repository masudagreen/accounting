{
    "name": "rucaro/accounting",
    "description": "RUCARO Accounting (forked) — domain layer rebuild with TDD",
    "type": "project",
    "license": "GPL-2.0-only",
    "require": {
        "php": ">=8.2",
        "ext-bcmath": "*",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "smarty/smarty": "^5.7",
        "brick/math": "^0.12",
        "dompdf/dompdf": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "mockery/mockery": "^1.6",
        "phpstan/phpstan": "^2.0",
        "rector/rector": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.65"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=unit",
        "test:integration": "phpunit --testsuite=integration",
        "test:golden": "phpunit --testsuite=golden",
        "phpstan": "phpstan analyse --memory-limit=1G",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix"
    }
}
