# Rucaro Accounting - environment template
# Copy to `.env` and fill in the real values. `.env` must stay out of Git.

# --- Application -------------------------------------------------------------
APP_NAME="Rucaro Accounting"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_LOCALE=ja
TZ=Asia/Tokyo

# --- HTTP / container ports --------------------------------------------------
APP_PORT=8080
DB_PORT=3306
PMA_PORT=8081

# --- Database (new app) ------------------------------------------------------
DB_DRIVER=mysql
DB_HOST=db
DB_NAME=rucaro
DB_USER=rucaro
DB_PASSWORD=rucaro
DB_ROOT_PASSWORD=root
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# --- Encryption (ADR-003) ----------------------------------------------------
# Generate with `php bin/cowork crypto:generate-key --raw`. Value is the
# base64url-encoded 32-byte master key. DO NOT COMMIT A REAL KEY.
APP_ENCRYPTION_KEY=
# Optional: only set when importing legacy Blowfish ciphertexts.
LEGACY_ENCRYPTION_SECRET=

# --- Logging -----------------------------------------------------------------
LOG_CHANNEL=stack
LOG_LEVEL=debug
LOG_PATH=storage/logs/app.log

# --- Claude API (Phase 5) ----------------------------------------------------
CLAUDE_API_KEY=
CLAUDE_EXTRACT_MODEL=claude-sonnet-4-6
CLAUDE_DRAFT_MODEL=claude-opus-4-7

# --- Mail / Approval (Phase 5) ----------------------------------------------
# MAIL_MAILER selects the adapter: null | smtp | memory.
# `null`   — NullMailSender, dispatches nothing (Phase 5 default).
# `smtp`   — SymfonyMailSender, uses MAIL_DSN below.
# `memory` — InMemoryMailSender, for local testing / demos.
MAIL_MAILER=null
# Symfony Mailer DSN. Examples:
#   smtp://user:pass@smtp.example.com:587
#   smtp://localhost:1025          (Mailpit / Mailhog)
MAIL_DSN=smtp://user:pass@localhost:1025
MAIL_FROM=no-reply@example.com
MAIL_FROM_NAME="Rucaro Accounting"
# Approval token lifetime (hours). Default 72h.
APPROVAL_TTL_HOURS=72
# Capability URL templates used in the approval email body.
APPROVAL_APPROVE_URL_TEMPLATE=${APP_URL}/api/v1/approvals/?token={token}&decision=approved
APPROVAL_REJECT_URL_TEMPLATE=${APP_URL}/api/v1/approvals/?token={token}&decision=rejected
